# ============================================================================
# Local credentials - template.
# Copy this file to `.env` and fill in your own keys. `.env` is gitignored.
#
# Real OS environment variables of the same name always take precedence over
# this file. The Java app reads it via com.mathify.util.MidtransConfig; the
# OCW import pipeline (tools/ocw-import) reads it via common._load_dotenv.
# ============================================================================

# --- Midtrans payments (Settings -> Access Keys on the Midtrans dashboard) ---
MIDTRANS_MERCHANT_ID=your-merchant-id
MIDTRANS_CLIENT_KEY=Mid-client-xxxxxxxxxxxxxxxx
MIDTRANS_SERVER_KEY=Mid-server-xxxxxxxxxxxxxxxx

# false = sandbox (app.sandbox.midtrans.com), true = production
MIDTRANS_IS_PRODUCTION=false

# Premium plan prices charged via Snap, in IDR (whole rupiah, no decimals)
MIDTRANS_PRICE_MONTHLY=125500
MIDTRANS_PRICE_YEARLY=1224500

# --- OCW import pipeline (tools/ocw-import) ---------------------------------
# Cloudinary, for hosting SLIDE PDFs (stage 3: cloudinary).
# Grab the full string from your Cloudinary dashboard
# (Account Details -> "API Environment variable").
CLOUDINARY_URL=cloudinary://your-api-key:your-api-secret@your-cloud-name

# Quiz extraction (stage 4: quiz). Default provider is "claude" and needs
# ANTHROPIC_API_KEY; the free local provider needs no secret. These optional
# overrides have working defaults - uncomment only to change them:
# QUIZ_PROVIDER=ollama
# OLLAMA_MODEL=qwen2.5vl:7b
# OLLAMA_HOST=http://localhost:11434
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx   # only for --provider claude